{
  "//": "Generated by context-engineering skill. The 'hooks' block enforces load-bearing rules from CLAUDE.md/AGENTS.md as actual guarantees. Hook scripts live in .claude/hooks/. Edit at your own risk; these turn prose into enforcement.",
  "//hooks-source": "See .claude/hooks/README.md for what each hook does and why.",
  "//permissions": "Read-only allowlist seeded by context-engineering to cut permission prompts for safe inspection commands. Writes/commits/pushes are intentionally NOT here — they run under the Autonomy charter and any commit-blocking hooks. Grow this with the fewer-permission-prompts skill. NOTE: if enforce_rules_as_hooks is opted out, still emit a settings.json carrying only this permissions block (drop the hooks block).",
  "//permissions-cmd-entries": "The last two allow entries below are the project's check/build commands; emit each only if its value exists. Drop any whose command resolved to 'none' or 'not configured'.",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(date:*)",
      "Bash(<!-- PARAMETERIZE: check_cmd -->:*)",
      "Bash(<!-- PARAMETERIZE: build_cmd -->:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "//": "Hook: block-env-commit. matcher=Bash; the script reads the stdin payload and blocks only staging of .env files. No 'if' filter — scoping lives in the script (see .claude/hooks/README.md). Always emitted.",
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-env-commit.sh"
          }
        ]
      },
      {
        "//OPTIONAL": "deploy_cli_hook — emit only if deploy_target_has_cli_conflict == true. matcher=Bash; the script scopes itself to deploy-CLI invocations.",
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-deploy-cli.sh"
          }
        ]
      },
      {
        "//OPTIONAL": "worktree_hook_bash — emit only if uses_visual_confirmation_gate == true. matcher=Bash; the script scopes itself to 'git worktree' commands.",
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-worktree.sh"
          }
        ]
      },
      {
        "//OPTIONAL": "worktree_hook_tool — emit only if uses_visual_confirmation_gate == true. Catches Claude Code's EnterWorktree tool. (Whether Agent isolation:worktree surfaces a PreToolUse event is undocumented — do not assume coverage.)",
        "matcher": "EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-worktree.sh"
          }
        ]
      }
    ]
  }
}
