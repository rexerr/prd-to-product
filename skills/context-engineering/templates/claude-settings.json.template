{
  "//": "Generated by context-engineering skill. The 'hooks' block enforces load-bearing rules from CLAUDE.md/AGENTS.md as actual guarantees. Hook scripts live in .claude/hooks/. Edit at your own risk; these turn prose into enforcement.",
  "//hooks-source": "See .claude/hooks/README.md for what each hook does and why.",
  "hooks": {
    "PreToolUse": [
      {
        "//": "Hook: block-env-commit. Blocks 'git add .env*'. Always emitted.",
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-env-commit.sh",
            "if": "Bash(git add .env*)"
          }
        ]
      },
      {
        "//OPTIONAL": "deploy_cli_hook — emit only if deploy_target_has_cli_conflict == true",
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-deploy-cli.sh",
            "if": "Bash(<!-- PARAMETERIZE: deploy_cli_lower --> *)"
          }
        ]
      },
      {
        "//OPTIONAL": "worktree_hook_bash — emit only if uses_visual_confirmation_gate == true",
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-worktree.sh",
            "if": "Bash(git worktree *)"
          }
        ]
      },
      {
        "//OPTIONAL": "worktree_hook_tool — emit only if uses_visual_confirmation_gate == true. Catches Claude Code's EnterWorktree tool and Agent isolation:worktree.",
        "matcher": "EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-worktree.sh"
          }
        ]
      }
    ]
  }
}
