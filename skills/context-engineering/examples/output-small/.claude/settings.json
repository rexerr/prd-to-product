{
  "//": "Generated by context-engineering skill. The 'hooks' block enforces load-bearing rules from CLAUDE.md as actual guarantees. Hook scripts live in .claude/hooks/. Edit at your own risk; these turn prose into enforcement.",
  "//hooks-source": "See .claude/hooks/README.md for what each hook does and why.",
  "hooks": {
    "PreToolUse": [
      {
        "//": "Hook: block-env-commit. Blocks 'git add .env*'.",
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-env-commit.sh",
            "if": "Bash(git add .env*)"
          }
        ]
      },
      {
        "//": "Hook: block-deploy-cli. Vercel CLI conflicts with auto-deploy.",
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-deploy-cli.sh",
            "if": "Bash(vercel *)"
          }
        ]
      },
      {
        "//": "Hook: block-worktree. Worktrees break the visual-confirmation commit gate.",
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-worktree.sh",
            "if": "Bash(git worktree *)"
          }
        ]
      },
      {
        "//": "Hook: block-worktree (Claude Code's EnterWorktree tool).",
        "matcher": "EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-worktree.sh"
          }
        ]
      }
    ]
  }
}
